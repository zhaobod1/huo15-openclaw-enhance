{
  "name": "@huo15/huo15-openclaw-enhance",
  "version": "6.1.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "火一五·克劳德·龙虾增强插件 v6.1.2 — 修复 model-router 的 PROVIDER_REGISTRY：旧的 deepseek/google-ai-studio/custom-sidus-ai 三个 provider id 都是不存在的（runtime 找不到 → 把 model id 整串塞给 sidus → 拒 400）。重写为只用实际注册的 sidus（priority 1，DeepSeek/GLM 全家）+ minimax（priority 2，极速兜底）；多模态分支（image/video/audio）暂时回退到 sidus pro 文本兜底，避免不存在 model id 死循环。继承 v6.1.1 trajectory-archiver v2 路径策略 + v6.0.0 npm 包改名 + v5.8.x 全部能力。",
  "type": "module",
  "main": "index.ts",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "build": {
      "openclawVersion": "2026.4.29"
    },
    "compat": {
      "pluginApi": ">=2026.4.24"
    }
  },
  "bin": {
    "openclaw-enhance-setup": "./scripts/setup.sh"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "release": "bash scripts/release.sh",
    "prepublishOnly": "npm run typecheck",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "enhance",
    "memory",
    "safety",
    "agent"
  ],
  "author": "jobzhao15",
  "license": "MIT",
  "peerDependencies": {
    "openclaw": "^2026.4.24"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.5.0"
  },
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "src/**/*",
    "templates/**/*",
    "scripts/**/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://cnb.cool/huo15/ai/huo15-openclaw-enhance"
  }
}
