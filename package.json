{
  "name": "@huo15/huo15-openclaw-enhance",
  "version": "6.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "火一五·克劳德·龙虾增强插件 v6.1.1 — chore-only re-publish 让 ClawHub Latest tag 跟上 6.1.x（6.1.0 publish 时 record 半成功但 tag 没刷新，Latest 仍停在 6.0.0；按 CLAUDE.md §7.6 不重试同版本号，bump patch 跳过）。零代码逻辑改动，继承 v6.1.0 trajectory-archiver v2 路径策略修正 + v6.0.0 npm 包改名 + v5.8.x 全部能力。",
  "type": "module",
  "main": "index.ts",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "build": {
      "openclawVersion": "2026.4.29"
    },
    "compat": {
      "pluginApi": ">=2026.4.24"
    }
  },
  "bin": {
    "openclaw-enhance-setup": "./scripts/setup.sh"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "release": "bash scripts/release.sh",
    "prepublishOnly": "npm run typecheck",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "enhance",
    "memory",
    "safety",
    "agent"
  ],
  "author": "jobzhao15",
  "license": "MIT",
  "peerDependencies": {
    "openclaw": "^2026.4.24"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.5.0"
  },
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "src/**/*",
    "templates/**/*",
    "scripts/**/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://cnb.cool/huo15/ai/huo15-openclaw-enhance"
  }
}
